    <diagram id="DoOWHB9VDvRhlUPOwQHh" name="Page-1">
        <mxGraphModel dx="2982" dy="1625" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    direction TB\n\n    class User {\n        &lt;&lt;abstract&gt;&gt;\n        -userId String\n        -name String\n        -email String\n        -passwordHash String\n        +login() void\n        +logout() void\n        +resetPassword() void\n    }\n\n    class Student {\n        -studentId String\n        -enrolledCourses List~Course~\n        +submitAssignment() void\n        +viewGrade() Grade\n        +viewFeedback() String\n        +getSubmissionHistory() List\n    }\n\n    class Professor {\n        -staffId String\n        -department String\n        +createAssignment() Assignment\n        +setGradingCriteria() void\n        +reviewSubmission() void\n        +overrideGrade() Grade\n        +setDueDate() void\n    }\n\n    class Admin {\n        -adminLevel int\n        +manageUsers() void\n        +generateReport() Report\n        +exportAuditLog() File\n        +configureSystem() void\n    }\n\n    class Course {\n        -courseId String\n        -name String\n        -semester String\n        -professorId String\n        +enrolStudent() void\n        +listAssignments() List\n        +syncToLMS() void\n    }\n\n    class Assignment {\n        -assignmentId String\n        -title String\n        -description String\n        -dueDateTime DateTime\n        -allowMultipleAttempts bool\n        -isOpen bool\n        +isAcceptingSubmissions() bool\n        +getLatestSubmission() Submission\n        +getCriteria() List\n    }\n\n    class Submission {\n        -submissionId String\n        -attemptNumber int\n        -submittedAt DateTime\n        -status SubmissionStatus\n        -repoUrl String\n        +runCode() ExecutionResult\n        +getGrade() Grade\n        +checkPlagiarism() PlagiarismReport\n        +isLate() bool\n    }\n\n    class GradingCriteria {\n        -criteriaId String\n        -metricWeights Map~String, float~\n        -testSuites List~TestSuite~\n        -passingThreshold float\n        +evaluate(s Submission) Grade\n        +addTestSuite(t TestSuite) void\n        +addMetric(name String, w float) void\n        +getMaxScore() float\n    }\n\n    class SourceFile {\n        -fileId String\n        -fileName String\n        -language String\n        -sizeBytes long\n        +validate() bool\n        +detectLanguage() String\n    }\n\n    class ExecutionResult {\n        -resultId String\n        -stdout String\n        -stderr String\n        -exitCode int\n        -executionTimeMs long\n        -memoryUsedMB int\n        +isPassed() bool\n        +getSummary() String\n    }\n\n    class Grade {\n        -gradeId String\n        -score float\n        -maxScore float\n        -isOverridden bool\n        -overrideReason String\n        -gradedAt DateTime\n        +toLetterGrade() String\n        +generateFeedback() String\n        +isFinal() bool\n    }\n\n    class AuditLog {\n        -logId String\n        -eventType String\n        -userId String\n        -timestamp DateTime\n        -details String\n        +exportForAudit() File\n        +queryByDate() List\n        +queryByUser() List\n    }\n\n    class PlagiarismReport {\n        -reportId String\n        -similarityScore float\n        -matchedSources List~String~\n        -generatedAt DateTime\n        -isFlagged bool\n        +flagForReview() void\n        +getSummary() String\n        +exceedsThreshold() bool\n    }\n\n    class CodeExecutionEngine {\n        -sandboxType String\n        -timeoutMs long\n        -memoryLimitMB int\n        -supportedLanguages List\n        +execute(f SourceFile) ExecutionResult\n        +runTests(s TestSuite) List\n        +getSupportedLangs() List\n    }\n\n    class GradingEngine {\n        -autoGradeEnabled bool\n        -weightingStrategy String\n        +grade(s Submission) Grade\n        +applyMetrics() float\n        +applyTests() float\n        +computeTotal() float\n        +publishGrade(g Grade) void\n    }\n\n    class TestSuite {\n        -suiteId String\n        -testCases List~TestCase~\n        -language String\n        +runAll() List~TestResult~\n        +getPassRate() float\n        +addTestCase(t TestCase) void\n    }\n\n    class Notification {\n        -notifId String\n        -recipientId String\n        -message String\n        -sentAt DateTime\n        -isRead bool\n        +send() void\n        +markRead() void\n    }\n\n    class GitHubConnector {\n        -apiToken String\n        -baseUrl String\n        -defaultBranch String\n        +fetchLatestCommit() SourceFile\n        +validateRepo() bool\n        +getCommitHistory() List\n    }\n\n    class PlagiarismService {\n        &lt;&lt;interface&gt;&gt;\n        +check(s Submission) PlagiarismReport\n        +compareWithPeers() float\n        +submitToExternal() void\n    }\n\n    class LMSConnector {\n        &lt;&lt;interface&gt;&gt;\n        +syncGrade(g Grade) void\n        +syncCourse(c Course) void\n        +pushNotification(n Notification) void\n    }\n\n    class TurnitinAdapter {\n        -apiKey String\n        -endpoint String\n        -timeoutMs long\n        +check(s Submission) PlagiarismReport\n        +compareWithPeers() float\n        +submitToExternal() void\n    }\n\n    class InternalPlagChecker {\n        -corpus SubmissionCorpus\n        -similarityAlgo String\n        +check(s Submission) PlagiarismReport\n        +compareWithPeers() float\n        +submitToExternal() void\n    }\n\n    class MainframeLMSAdapter {\n        -endpoint String\n        -retryPolicy RetryPolicy\n        -authToken String\n        +syncGrade(g Grade) void\n        +syncCourse(c Course) void\n        +pushNotification(n Notification) void\n    }\n\n    %% Inheritance\n    User &lt;|-- Student\n    User &lt;|-- Professor\n    User &lt;|-- Admin\n\n    %% Aggregation\n    Course \&quot;1\&quot; o-- \&quot;1..*\&quot; Assignment : contains\n\n    %% Composition\n    Assignment \&quot;1\&quot; *-- \&quot;0..*\&quot; Submission : owns\n    Assignment \&quot;1\&quot; *-- \&quot;1\&quot; GradingCriteria : defines\n    Submission \&quot;1\&quot; *-- \&quot;1..*\&quot; SourceFile : contains\n    Submission \&quot;1\&quot; *-- \&quot;1\&quot; ExecutionResult : produces\n    GradingCriteria \&quot;1\&quot; *-- \&quot;0..*\&quot; TestSuite : includes\n\n    %% Directed associations\n    Professor --&gt; Assignment : creates\n    Student --&gt; Submission : submits\n    Submission --&gt; Grade : produces\n    Submission --&gt; PlagiarismReport : generates\n    Admin --&gt; AuditLog : accesses\n    Student --&gt; Notification : receives\n\n    %% Dependencies\n    Grade ..&gt; AuditLog : triggers\n    GradingEngine ..&gt; Grade : creates\n    GradingEngine ..&gt; GradingCriteria : uses\n    GradingEngine ..&gt; CodeExecutionEngine : uses\n    GradingEngine ..&gt; LMSConnector : syncs\n    CodeExecutionEngine ..&gt; ExecutionResult : produces\n    GitHubConnector ..&gt; SourceFile : fetches\n    Submission ..&gt; GitHubConnector : uses\n    PlagiarismReport ..&gt; PlagiarismService : uses\n\n    %% Realization\n    TurnitinAdapter ..|&gt; PlagiarismService\n    InternalPlagChecker ..|&gt; PlagiarismService\n    MainframeLMSAdapter ..|&gt; LMSConnector&quot;&#xa;}" id="3">
